{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "language": "english",
  "tui": "fullscreen",
  "autoMemoryEnabled": true,
  "editorMode": "vim",
  "showTurnDuration": true,
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(dotnet run *)"
    ],
    "ask": [
      "Bash(git *)"
    ],
    "deny": [
      "Bash(curl *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ],
    "defaultMode": "plan"
  },
  "sandbox": {
    "enabled": true
  }
}
