{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "language": "english",
    "tui": "fullscreen",
    "autoMemoryEnabled": true,
    "editorMode": "vim",
    "showTurnDuration": true,
    "permissions": {
        "allow": [
            "Bash(npm run *)",
            "Bash(dotnet run *)",
            "Bash(git show *)",
            "Bash(git log *)",
            "Bash(find *)"
        ],
        "ask": [
            "Bash(git *)"
        ],
        "deny": [
            "Bash(curl *)",
            "Read(./.env)",
            "Read(./.env.*)",
            "Read(./secrets/**)"
        ],
        "defaultMode": "plan"
    },
    "mcpServers": {
        "playwright": {
            "command": "bunx",
            "args": [
                "@playwright/mcp@0.0.70"
            ]
        },
        "atlassian-rovo": {
            "command": "bunx",
            "args": [
                "-y",
                "mcp-remote@latest",
                "https://mcp.atlassian.com/v1/mcp/authv2"
            ]
        }
    },
    "sandbox": {
        "enabled": true
    }
}
