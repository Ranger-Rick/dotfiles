{
    "$schema": "https://opencode.ai/config.json",
    "share": "disabled",
    "mcp": {
        "playwright": {
            "enabled": true,
            "type": "local",
            "command": [
                "bunx",
                "@playwright/mcp@0.0.70"
            ]
        },
        "atlassian-rovo": {
            "enabled": true,
            "type": "local",
            "command": [
                "bunx",
                "-y",
                "mcp-remote@latest",
                "https://mcp.atlassian.com/v1/mcp/authv2"
            ]
        }
    },
    "permission": {
        "external_directory": "deny",
        "read": {
            "*": "allow",
            "*.env": "deny",
            "*.env.*": "deny",
            "**/node_modules/**": "allow"
        },
        "edit": {
            "*": "allow"
        },
        "bash": "ask",
        "webfetch": "allow",
        "websearch": "allow"
    }
}
